{
  "distributed-cache": {
    "owners": "2",
    "mode": "SYNC",
    "statistics": false,
    "encoding": {
      "media-type": "application/x-protostream"
    },
    "locking": {
      "isolation": "REPEATABLE_READ",
      "acquire-timeout": "1500ms",
      "striping": true
    },
    "transaction": {
      "mode": "NON_XA",
      "locking": "OPTIMISTIC"
    },
    "memory": {
      "storage": "OFF_HEAP"
    }
  }
}